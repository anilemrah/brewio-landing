---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Brewio — Every cup tells a story',
  description = 'Log your coffees, track brew methods, rate beans, and discover your taste patterns.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Playfair+Display:ital,wght@0,600;0,700;1,600;1,700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --cream: #FAF7F2;
    --cream-subtle: #F5F0E8;
    --dark: #1A1714;
    --dark-surface: #1E1B18;
    --dark-card: #2C2720;
    --brown: #6B3A1F;
    --amber: #C47B30;
    --amber-light: #D4904A;
    --amber-glow: rgba(196, 123, 48, 0.15);
    --text-dark: #2C2C2A;
    --text-muted: #888780;
    --text-light: #B4B2A9;
    --border: #D3D1C7;
    --border-subtle: #F0EDE8;
    --border-dark: #3A342E;

    --font-sans: 'DM Sans', system-ui, sans-serif;
    --font-serif: 'Playfair Display', Georgia, serif;
    --font-mono: 'DM Mono', 'Courier New', monospace;
  }

  html {
    scroll-behavior: smooth;
    background: var(--dark);
  }

  body {
    font-family: var(--font-sans);
    background: var(--cream);
    color: var(--text-dark);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  a {
    text-decoration: none;
    color: inherit;
  }
</style>
