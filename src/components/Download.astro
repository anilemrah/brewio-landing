---
---

<section id="download" class="download">
  <div class="download-glow" aria-hidden="true"></div>

  <div class="download-inner">
    <div class="download-badge">Free to download</div>

    <h2 class="download-heading">
      Your coffee journey<br />starts <em>now.</em>
    </h2>

    <p class="download-sub">
      Log your first brew, time your pour-over, and start discovering
      what's really in your cup.
    </p>

    <div class="download-ctas">
      <a href="#" class="badge-link">
        <img src="/badge-app-store.svg" alt="Download on the App Store" class="badge badge-apple" />
      </a>
      <a href="#" class="badge-link">
        <img src="/badge-google-play.png" alt="Get it on Google Play" class="badge badge-google" />
      </a>
    </div>

    <div class="download-meta">
      <span>Free forever</span>
      <span class="sep">·</span>
      <span>No ads</span>
      <span class="sep">·</span>
      <span>Optional premium</span>
      <span class="sep">·</span>
      <span>15+ languages</span>
    </div>
  </div>
</section>

<style>
  .download {
    background: var(--dark);
    padding: 9rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .download-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(196,123,48,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .download-inner {
    position: relative;
    max-width: 620px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.625rem;
  }

  .download-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber);
    background: rgba(196,123,48,0.1);
    border: 1px solid rgba(196,123,48,0.2);
    padding: 0.4rem 1.1rem;
    border-radius: 100px;
  }

  .download-heading {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 4.5vw, 4.25rem);
    color: var(--cream);
    letter-spacing: -0.025em;
    line-height: 1.08;
  }

  .download-heading em {
    color: var(--amber);
    font-style: italic;
  }

  .download-sub {
    font-size: 1.05rem;
    color: rgba(250,247,242,0.5);
    line-height: 1.7;
    max-width: 420px;
  }

  .download-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    margin-top: 0.5rem;
  }

  .badge-link {
    display: block;
    transition: transform 0.2s, opacity 0.2s;
  }

  .badge-link:hover { transform: translateY(-2px); opacity: 0.88; }

  .badge { display: block; height: 52px; width: auto; }
  .badge-google { height: 62px; }

  .download-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    font-size: 0.82rem;
    color: rgba(250,247,242,0.3);
  }

  .sep { color: rgba(250,247,242,0.15); }

  @media (max-width: 480px) {
    .download { padding: 5rem 1.25rem; }
    .download-heading { font-size: 2.25rem; }
    .download-ctas { flex-direction: column; align-items: center; }
    .badge { height: 46px; }
    .badge-google { height: 55px; }
    .download-meta { font-size: 0.75rem; gap: 0.5rem; }
  }
</style>
