---
---

<section id="download" class="download">
  <div class="download-glow" aria-hidden="true"></div>

  <div class="download-inner">
    <div class="download-badge">Free to download</div>

    <h2 class="download-heading">
      Your coffee journey<br />starts <em>now.</em>
    </h2>

    <p class="download-sub">
      Log your first brew, time your pour-over, and start discovering
      what's really in your cup.
    </p>

    <div class="download-ctas">
      <a href="#" class="store-btn store-apple">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71,19.5C17.88,20.74 17,21.95 15.66,21.97C14.32,22 13.89,21.18 12.37,21.18C10.84,21.18 10.37,21.95 9.1,22C7.78,22.05 6.8,20.68 5.96,19.47C4.25,17 2.94,12.45 4.7,9.39C5.57,7.87 7.13,6.91 8.82,6.88C10.1,6.86 11.32,7.75 12.11,7.75C12.89,7.75 14.37,6.68 15.92,6.84C16.57,6.87 18.39,7.1 19.56,8.82C19.47,8.88 17.39,10.1 17.41,12.63C17.44,15.65 20.06,16.66 20.09,16.67C20.06,16.74 19.67,18.11 18.71,19.5ZM13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z"/>
        </svg>
        <div class="btn-text">
          <span class="btn-eyebrow">Download on the</span>
          <span class="btn-label">App Store</span>
        </div>
      </a>

      <a href="#" class="store-btn store-google">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.5,12.92 20.16,13.19L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
        </svg>
        <div class="btn-text">
          <span class="btn-eyebrow">Get it on</span>
          <span class="btn-label">Google Play</span>
        </div>
      </a>
    </div>

    <div class="download-meta">
      <span>Free forever</span>
      <span class="sep">·</span>
      <span>No ads</span>
      <span class="sep">·</span>
      <span>Optional premium</span>
      <span class="sep">·</span>
      <span>15+ languages</span>
    </div>
  </div>
</section>

<style>
  .download {
    background: var(--dark);
    padding: 9rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .download-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(196,123,48,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .download-inner {
    position: relative;
    max-width: 620px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.625rem;
  }

  .download-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber);
    background: rgba(196,123,48,0.1);
    border: 1px solid rgba(196,123,48,0.2);
    padding: 0.4rem 1.1rem;
    border-radius: 100px;
  }

  .download-heading {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 4.5vw, 4.25rem);
    color: var(--cream);
    letter-spacing: -0.025em;
    line-height: 1.08;
  }

  .download-heading em {
    color: var(--amber);
    font-style: italic;
  }

  .download-sub {
    font-size: 1.05rem;
    color: rgba(250,247,242,0.5);
    line-height: 1.7;
    max-width: 420px;
  }

  .download-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .store-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.75rem;
    border-radius: 14px;
    transition: transform 0.2s, box-shadow 0.2s;
    cursor: pointer;
  }

  .store-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0,0,0,0.3);
  }

  .store-btn svg {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .btn-text {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .btn-eyebrow {
    font-size: 0.62rem;
    font-weight: 400;
    opacity: 0.75;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .btn-label {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .store-apple {
    background: white;
    color: #1a1a1a;
  }

  .store-google {
    background: transparent;
    color: var(--cream);
    border: 1.5px solid rgba(250,247,242,0.18);
  }

  .store-google:hover {
    border-color: rgba(250,247,242,0.38);
  }

  .download-meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    font-size: 0.82rem;
    color: rgba(250,247,242,0.3);
  }

  .sep { color: rgba(250,247,242,0.15); }

  @media (max-width: 480px) {
    .download { padding: 5rem 1.25rem; }
    .store-btn { padding: 0.8rem 1.4rem; }
  }
</style>
