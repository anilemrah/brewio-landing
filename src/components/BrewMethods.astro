---
const methods = [
  { name: 'V60',          type: 'Pour Over',    time: '3–4 min',   ratio: '1:15',  diff: 'Medium' },
  { name: 'AeroPress',    type: 'Pressure',     time: '1–2 min',   ratio: '1:14',  diff: 'Easy'   },
  { name: 'French Press', type: 'Immersion',    time: '4 min',     ratio: '1:12',  diff: 'Easy'   },
  { name: 'Chemex',       type: 'Pour Over',    time: '4–5 min',   ratio: '1:17',  diff: 'Medium' },
  { name: 'Moka Pot',     type: 'Stove Top',    time: '5–7 min',   ratio: '1:7',   diff: 'Easy'   },
  { name: 'Espresso',     type: 'Pressure',     time: '25–30 sec', ratio: '1:2.5', diff: 'Hard'   },
  { name: 'Cold Brew',    type: 'Immersion',    time: '12–18 hr',  ratio: '1:8',   diff: 'Easy'   },
  { name: 'Drip Machine', type: 'Auto Drip',    time: '5–8 min',   ratio: '1:16',  diff: 'Easy'   },
  { name: 'Freddo',       type: 'Iced',         time: '2–3 min',   ratio: '1:3.5', diff: 'Medium' },
  { name: 'Kalita Wave',  type: 'Pour Over',    time: '3–4 min',   ratio: '1:15',  diff: 'Medium' },
  { name: 'Siphon',       type: 'Vacuum',       time: '3–5 min',   ratio: '1:14',  diff: 'Hard'   },
  { name: 'Ibrik',        type: 'Traditional',  time: '3–5 min',   ratio: '1:8',   diff: 'Medium' },
];
---

<section id="brew-methods" class="brew-methods">
  <div class="bm-inner">
    <div class="section-eyebrow">Brew Methods</div>
    <h2 class="section-heading">
      12 methods.<br /><em>Infinite possibilities.</em>
    </h2>
    <p class="section-sub">
      Every method comes with a built-in step-by-step timer, grind size guide,
      and dose recommendation. Beginner or pro — there's a guide for you.
    </p>
  </div>

  <div class="scroll-area">
    <div class="scroll-track">
      {methods.map(m => (
        <div class="method-card">
          <div class="mc-header">
            <span class="mc-name">{m.name}</span>
            <span class={`mc-diff mc-diff--${m.diff.toLowerCase()}`}>{m.diff}</span>
          </div>
          <div class="mc-type">{m.type}</div>
          <div class="mc-stats">
            <div class="mc-stat">
              <span class="ms-val">{m.time}</span>
              <span class="ms-key">Time</span>
            </div>
            <div class="mc-stat">
              <span class="ms-val">{m.ratio}</span>
              <span class="ms-key">Ratio</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="scroll-fade scroll-fade-left"  aria-hidden="true"></div>
  <div class="scroll-fade scroll-fade-right" aria-hidden="true"></div>
</section>

<style>
  .brew-methods {
    background: var(--dark-surface);
    padding: 7rem 0;
    overflow: hidden;
    position: relative;
  }

  .bm-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-bottom: 0.875rem;
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    color: var(--cream);
    letter-spacing: -0.025em;
    margin-bottom: 0.875rem;
    line-height: 1.12;
  }

  .section-heading em {
    color: var(--amber);
    font-style: italic;
  }

  .section-sub {
    font-size: 1.05rem;
    color: rgba(250,247,242,0.48);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Horizontal scroll */
  .scroll-area {
    overflow-x: auto;
    padding: 0.5rem 0 2.5rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  .scroll-area::-webkit-scrollbar { display: none; }

  .scroll-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    padding: 0 2rem;
  }

  /* Fade edges */
  .scroll-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    pointer-events: none;
    z-index: 2;
  }

  .scroll-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--dark-surface), transparent);
  }

  .scroll-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--dark-surface), transparent);
  }

  /* Cards */
  .method-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 18px;
    padding: 1.375rem;
    width: 190px;
    flex-shrink: 0;
    transition: background 0.22s, border-color 0.22s, transform 0.22s;
    cursor: default;
  }

  .method-card:hover {
    background: rgba(196,123,48,0.07);
    border-color: rgba(196,123,48,0.22);
    transform: translateY(-4px);
  }

  .mc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.3rem;
  }

  .mc-name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--cream);
  }

  .mc-diff {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
  }

  .mc-diff--easy   { background: rgba(22,163,74,0.14);  color: #4ade80; border: 1px solid rgba(22,163,74,0.2);  }
  .mc-diff--medium { background: rgba(196,123,48,0.14); color: var(--amber-light); border: 1px solid rgba(196,123,48,0.2); }
  .mc-diff--hard   { background: rgba(220,38,38,0.14);  color: #f87171; border: 1px solid rgba(220,38,38,0.2);  }

  .mc-type {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(250,247,242,0.35);
    margin-bottom: 1rem;
  }

  .mc-stats {
    display: flex;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.06);
    padding-top: 0.875rem;
  }

  .mc-stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .ms-val {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--cream);
  }

  .ms-key {
    font-size: 0.62rem;
    color: rgba(250,247,242,0.3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 580px) {
    .brew-methods { padding: 5rem 0; }
    .scroll-fade { width: 40px; }
    .scroll-track { padding: 0 1rem; }
  }
</style>
