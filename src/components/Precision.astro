---
---

<section id="precision" class="precision">
  <div class="precision-inner">

    <!-- Text side -->
    <div class="precision-text">
      <div class="section-eyebrow">Precision Tools</div>
      <h2 class="section-heading">Built for <em>dialing&nbsp;in.</em></h2>
      <p class="section-sub">
        Calculate your dose. Track your extraction. Nail the ratio.
        Whether you're pulling espresso or timing a Chemex bloom,
        Brewio gives you the numbers you need.
      </p>

      <ul class="check-list">
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Coffee-to-water ratio calculator
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Extraction yield (EY%) from TDS%
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Grind size guide per brew method
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Step-by-step brew timers with alerts
        </li>
      </ul>
    </div>

    <!-- Terminal visual -->
    <div class="terminal" aria-hidden="true">
      <div class="terminal-bar">
        <div class="dot dot-r"></div>
        <div class="dot dot-y"></div>
        <div class="dot dot-g"></div>
        <span class="terminal-title">brewio — dose &amp; extraction</span>
      </div>

      <div class="terminal-body">

        <div class="block">
          <span class="comment">// INPUT</span>
          <div class="row">
            <span class="key">coffee</span>
            <span class="eq">=</span>
            <span class="val amber">18.0</span>
            <span class="unit">g</span>
          </div>
          <div class="row">
            <span class="key">water</span>
            <span class="eq">=</span>
            <span class="val amber">300</span>
            <span class="unit">ml</span>
          </div>
        </div>

        <div class="divider"></div>

        <div class="block">
          <span class="comment">// CALCULATED RATIO</span>
          <div class="row">
            <span class="key">ratio</span>
            <span class="eq">=</span>
            <span class="val cream">1 : 16.7</span>
          </div>
          <div class="row">
            <span class="key">grind</span>
            <span class="eq">=</span>
            <span class="val cream">Medium Fine</span>
          </div>
          <div class="row">
            <span class="key">temp</span>
            <span class="eq">=</span>
            <span class="val cream">93–95</span>
            <span class="unit">°C</span>
          </div>
        </div>

        <div class="divider"></div>

        <div class="block">
          <span class="comment">// EXTRACTION YIELD</span>
          <div class="row">
            <span class="key">TDS</span>
            <span class="eq">=</span>
            <span class="val amber">1.35</span>
            <span class="unit">%</span>
          </div>
          <div class="row">
            <span class="key">beverage</span>
            <span class="eq">=</span>
            <span class="val amber">250</span>
            <span class="unit">ml</span>
          </div>
          <div class="row">
            <span class="key">EY</span>
            <span class="eq">=</span>
            <span class="val green">18.75</span>
            <span class="unit">%</span>
            <span class="badge badge-good">IDEAL</span>
          </div>
        </div>

        <div class="cursor"></div>
      </div>
    </div>

  </div>
</section>

<style>
  .precision {
    background: var(--cream);
    padding: 7rem 2rem;
  }

  .precision-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--amber);
    margin-bottom: 0.875rem;
  }

  .section-heading {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3vw, 3rem);
    color: var(--text-dark);
    letter-spacing: -0.025em;
    line-height: 1.12;
    margin-bottom: 1rem;
  }

  .section-heading em {
    color: var(--brown);
    font-style: italic;
  }

  .section-sub {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .check-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .check-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--text-dark);
  }

  .check-list li svg {
    width: 17px;
    height: 17px;
    flex-shrink: 0;
    color: var(--amber);
  }

  /* Terminal */
  .terminal {
    background: #0F0D0C;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 24px 64px rgba(0,0,0,0.22);
    overflow: hidden;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    background: rgba(255,255,255,0.015);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .terminal-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(250,247,242,0.28);
    margin-left: 0.25rem;
  }

  .terminal-body {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .block {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.875rem 0;
  }

  .comment {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: rgba(250,247,242,0.18);
    margin-bottom: 0.125rem;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .key {
    width: 80px;
    flex-shrink: 0;
    color: rgba(250,247,242,0.42);
  }

  .eq {
    color: rgba(250,247,242,0.2);
  }

  .val { font-weight: 500; }
  .val.amber { color: var(--amber-light); }
  .val.cream  { color: var(--cream); }
  .val.green  { color: #4ade80; }

  .unit {
    font-size: 0.78rem;
    color: rgba(250,247,242,0.28);
  }

  .badge {
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.12rem 0.5rem;
    border-radius: 4px;
    margin-left: 0.25rem;
  }

  .badge-good {
    background: rgba(22,163,74,0.14);
    color: #4ade80;
    border: 1px solid rgba(22,163,74,0.22);
  }

  .divider {
    height: 1px;
    background: rgba(255,255,255,0.05);
  }

  .cursor {
    width: 8px;
    height: 15px;
    background: var(--amber);
    border-radius: 1.5px;
    margin-top: 0.625rem;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @media (max-width: 900px) {
    .precision-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 580px) {
    .precision { padding: 5rem 1.25rem; }
  }
</style>
